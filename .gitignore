# Node
node_modules/
npm-debug.log*
*.tsbuildinfo

# Harness scratch — per-run evidence the loop writes into a target repo lives in
# <target>/.ui-evolve/ inside THAT repo; this entry guards stray copies here too.
.ui-evolve/

# Playwright
/test-results/
/playwright-report/
/blob-report/

# Agent / tooling session scratch (never ship to this public repo)
.ai-workspace/
.claude/

# Build / quarantine scratch + macOS
_quarantine*
.DS_Store

# Taste-exemplar pole screenshots are the user's OWN local renders (a four-pole
# picture book the judge reads). They are kept LOCAL and NEVER committed — a résumé
# full-page shot can render employer/PII content, and a text grep is blind to pixels.
# Ignore the pole subdirs + every PNG under the tree, but KEEP the committed README
# (the slot doc) trackable so the dir is documented in the repo.
references/taste-exemplars/**/*.png
references/taste-exemplars/*/
!references/taste-exemplars/README.md

# Local-only
*.local
.env
.env.*
